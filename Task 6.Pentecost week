#include <iostream>
using namespace std;
int main() {
    int year,d,m;
   cout<<"Enter year:";
    cin>>year;
    int a=year%19;
    int b=year/100;
    int c=year%100;
    int h=(19*a+b-b/4-(b-(b+8)/25+1)/3 +15)%30;
    int l=(32+2*(b%4)+2*(c/4)-h-(c%4)) %7;
    int e=(a+11*h+22*l)/451;
    m=(h+l-7*e+114)/31;
    d=((h+l-7*e+114)%31)+1;
    d+=49; 
    cout<<"\nPentecost Sunday:"<<d<<"/"<<m<<"/"<<year<<endl;
    cout<<"Pentecost Week:\n";
    for(int i=0;i<7;i++) {
        cout<<"Day"<<i+1<<":"<<d+i<<"/"<<m<<"/"<<year<<endl;
    }
    return 0;
}
